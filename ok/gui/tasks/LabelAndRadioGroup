from PySide6.QtWidgets import QWidget, QHBoxLayout, QButtonGroup
from qfluentwidgets import RadioButton

from ok.gui.tasks.ConfigLabelAndWidget import ConfigLabelAndWidget


class LabelAndRadioGroup(ConfigLabelAndWidget):
    def __init__(self, config_desc, options, config, key: str):
        super().__init__(config_desc, config, key)
        
        self.key = key
        self.options = list(options)
        self.suppress_guard = False

        self.radio_container = QWidget()
        self.radio_layout = QHBoxLayout(self.radio_container)
        self.radio_layout.setContentsMargins(0, 0, 0, 0)
        self.radio_layout.setSpacing(16)

        self.button_group = QButtonGroup(self)
        self.buttons = []

        current_val = self.config.get(self.key)

        for index, opt in enumerate(self.options):
            btn = RadioButton(opt)
            self.button_group.addButton(btn, index)
            self.radio_layout.addWidget(btn)
            self.buttons.append(btn)

            if opt == current_val:
                btn.setChecked(True)

        self.button_group.idClicked.connect(self._on_button_clicked)

        self.radio_layout.addStretch(1)
        self.add_widget(self.radio_container, stretch=1)

    def _on_button_clicked(self, btn_id: int):
        """当单选组内任意按钮被点击时触发（仅触发一次）"""
        if self.suppress_guard:
            return
            
        # 通过 idClicked 传进来的 btn_id 就是我们在上面 addButton 时绑定的 index
        if 0 <= btn_id < len(self.options):
            target_value = self.options[btn_id]
            self.update_config(target_value)

    def update_value(self):
        """外部数据变动时同步更新 UI 状态"""
        self.suppress_guard = True
        current_val = self.config.get(self.key)
        for i, opt in enumerate(self.options):
            if opt == current_val:
                self.buttons[i].setChecked(True)
                break
        self.suppress_guard = False
